{
  "name": "adgenius-bot",
  "version": "1.0.0",
  "description": "Production-ready Telegram AI Video Ad Generator Bot with SaaS architecture",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "test": "jest",
    "migrate": "node dist/database/migrations.js",
    "seed": "node dist/database/seed.js"
  },
  "keywords": [
    "telegram",
    "bot",
    "ai",
    "video",
    "generator",
    "saas"
  ],
  "author": "AI-Analysis-tab",
  "license": "MIT",
  "dependencies": {
    "telegraf": "^4.15.0",
    "@telegraf/types": "^7.0.0",
    "@supabase/supabase-js": "^2.38.0",
    "stripe": "^14.0.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.1",
    "bull": "^4.11.0",
    "redis": "^4.6.0",
    "ethers": "^6.9.0",
    "web3": "^1.10.0",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.1",
    "joi": "^17.11.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "ts-node": "^10.9.0",
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "prettier": "^3.1.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "@types/jest": "^29.5.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
